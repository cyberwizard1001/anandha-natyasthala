---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "Anandha Natyasthala" } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-[#ffffff] text-[#1f1a17]">
    <slot />
  </body>
</html>