<section id="contact" class="content-pad section-gap pt-0">
  <div class="grid gap-10 lg:grid-cols-2">
    <div>
      <h2 class="text-[2.4rem] leading-tight sm:text-[3rem] lg:text-[3.4rem]">Get in touch</h2>
      <p class="mt-4 max-w-xl text-sm leading-7 text-[#6f655d] sm:text-base">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.
      </p>

      <div class="mt-8 space-y-6">
        <div>
          <h3 class="text-lg font-semibold">Email</h3>
          <a class="text-sm text-[#6f655d] underline" href="mailto:hello@anandhanatyasthala.com">
            hello@anandhanatyasthala.com
          </a>
        </div>
        <div>
          <h3 class="text-lg font-semibold">Socials</h3>
          <a class="text-sm text-[#6f655d] underline" href="#">
            Instagram
          </a>
        </div>
      </div>
    </div>

    <form class="soft-card p-6 sm:p-8">
      <h3 class="text-[1.8rem]">Query?</h3>
      <div class="mt-6 grid gap-4">
        <div>
          <label class="label" for="name">Name</label>
          <input class="input" id="name" name="name" type="text" placeholder="Adam Webworker" />
        </div>
        <div>
          <label class="label" for="query-email">Email</label>
          <input class="input" id="query-email" name="email" type="email" placeholder="thisisemail@gmail.com" />
        </div>
        <div>
          <label class="label" for="message">Message</label>
          <textarea class="input min-h-32" id="message" name="message" placeholder="This is a message and it is supposed to be mapped to the response of the message to the receiver."></textarea>
        </div>
        <button type="submit" class="btn-primary">Submit</button>
      </div>
    </form>
  </div>
</section>
