<section class="content-pad section-gap">
  <div class="grid items-start gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-12">
    <div class="overflow-hidden rounded-[1.25rem]">
      <img src="/images/register.jpg" alt="Register interest image" class="aspect-[4/5] w-full object-cover" />
    </div>

    <div>
      <h2 class="text-[2.4rem] leading-tight sm:text-[3rem] lg:text-[3.4rem]">Register interest</h2>
      <p class="mt-4 max-w-xl text-sm leading-7 text-[#6f655d] sm:text-base">
        Leave your details and we will contact you with class timings, fees, and enrolment details.
      </p>

      <form class="mt-8 grid max-w-xl gap-4">
        <div>
          <label class="label" for="interest-email">Email</label>
          <input class="input" id="interest-email" name="email" type="email" placeholder="thisisemail@gmail.com" />
        </div>
        <button type="submit" class="btn-primary">Submit</button>
      </form>
    </div>
  </div>
</section>
