---
const heroImage = "/images/hero-dancer.jpg";
const instagramLogo = "/images/instagram-logo.jpg";
---

<section class="content-pad pt-4 sm:pt-5 lg:pt-6">
    <div
        class="relative overflow-hidden rounded-[1.5rem] min-h-[34rem] sm:min-h-[42rem] lg:min-h-[48rem]"
        style="background: linear-gradient(180deg, rgba(255,232,208,1) 0%, rgba(255,232,208,1) 23%, rgba(255,254,252,1) 80%, rgba(255,255,255,1) 100%);"
    >
        <div
            class="grid min-h-[34rem] items-center gap-10 px-6 py-8 sm:min-h-[42rem] sm:px-10 sm:py-10 lg:min-h-[48rem] lg:grid-cols-2 lg:px-12 lg:py-12"
        >
            <div class="max-w-2xl self-center">
                <h1
                    class="max-w-[12ch] text-[3rem] leading-[0.92] text-[#c37616] sm:text-[4.3rem] lg:text-[5.4rem]"
                >
                    Anandha<br />Natyasthala
                </h1>

                <p
                    class="mt-7 max-w-sm text-[0.92rem] italic leading-6 text-[#8f6a53] sm:text-base lg:mt-8"
                >
                    Anandam Nityena Samarpitam<br />
                    Bliss Offered Through Dance
                </p>

                <div
                    class="mt-14 flex items-center gap-3 text-sm text-[#1f1a17] sm:mt-16"
                >
                    <img
                        src={instagramLogo}
                        alt="Instagram logo"
                        class="aspect-[1/1]"
                    />
                    <span>@anandhanatyasthala</span>
                </div>
            </div>

            <div class="flex items-center justify-center lg:justify-end">
                <div
                    class="w-full max-w-[19rem] overflow-hidden rounded-[1.4rem] bg-transparent sm:max-w-[22rem] lg:max-w-[29rem]"
                >
                    <img
                        src={heroImage}
                        alt="Classical dancer in performance pose"
                        class="block aspect-[4/5] h-full w-full object-cover"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
